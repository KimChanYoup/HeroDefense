# Database
POSTGRES_DB=hero_defense
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme_password_here
DB_PORT=5432

# Backend
JWT_SECRET=changeme_jwt_secret_here
NODE_ENV=development
BACKEND_PORT=3000

# Frontend
FRONTEND_PORT=5173
# With Nginx (HTTPS) - use these (port 8443 for non-root machines):
VITE_API_URL=https://localhost:8443
VITE_WS_URL=wss://localhost:8443
# If running as root or with CAP_NET_BIND_SERVICE, use port 443:
# VITE_API_URL=https://localhost
# VITE_WS_URL=wss://localhost
# Without Nginx (direct) - use these:
# VITE_API_URL=https://localhost:3000
# VITE_WS_URL=wss://localhost:3000
