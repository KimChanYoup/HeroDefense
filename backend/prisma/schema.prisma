generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// 유저 & 소셜
// ========================

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  username      String    @unique
  passwordHash  String    @map("password_hash")
  avatarUrl     String?   @map("avatar_url")
  level         Int       @default(1)
  experience    Int       @default(0)
  gold          Int       @default(500)
  crystals      Int       @default(0)
  isOnline        Boolean   @default(false) @map("is_online")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lastLogin       DateTime? @map("last_login")
  bestWave        Int       @default(0) @map("best_wave")
  bestScore       Int       @default(0) @map("best_score")
  totalClears     Int       @default(0) @map("total_clears")
  totalGoldEarned Int       @default(0) @map("total_gold_earned")
  protagonistSave  Json?     @map("protagonist_save")
  ownedHeroIds     Json      @default("[]") @map("owned_hero_ids")
  offenseProgress  Json      @default("{}") @map("offense_progress")
  tutorialProgress String    @default("none") @map("tutorial_progress")

  // Relations
  heroes        UserHero[]
  achievements  UserAchievement[]
  sentMessages  ChatMessage[]     @relation("sender")
  friendsOf     Friendship[]      @relation("user")
  friendsWith   Friendship[]      @relation("friend")
  gameSessions  GameSessionPlayer[]

  @@map("users")
}

model Friendship {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  friendId  Int      @map("friend_id")
  status    String   @default("pending") // pending, accepted, blocked
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation("user", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("friend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@map("friendships")
}

// ========================
// 게임 데이터 정의
// ========================

model Race {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  displayName String  @map("display_name")
  synergy3    String? @map("synergy_3")
  synergy4    String? @map("synergy_4")
  synergy5    String? @map("synergy_5")

  heroes HeroTemplate[]

  @@map("races")
}

model Element {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  displayName String  @map("display_name")
  synergy3    String? @map("synergy_3")
  synergy4    String? @map("synergy_4")
  synergy5    String? @map("synergy_5")

  heroes HeroTemplate[]

  @@map("elements")
}

model Faction {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  displayName String  @map("display_name")
  description String?
  synergy3    String? @map("synergy_3")

  heroes HeroTemplate[]

  @@map("factions")
}

model GameClass {
  id          Int    @id @default(autoincrement())
  name        String @unique
  displayName String @map("display_name")

  specs Spec[]

  @@map("classes")
}

model Spec {
  id          Int     @id @default(autoincrement())
  classId     Int     @map("class_id")
  name        String
  displayName String  @map("display_name")
  role        String  // tank, melee_dps, ranged_dps, healer, cc
  rangeType   String  @map("range_type") // melee, ranged
  description String?

  gameClass    GameClass      @relation(fields: [classId], references: [id])
  heroes       HeroTemplate[]
  skills       Skill[]
  talentNodes  TalentNode[]

  @@unique([classId, name])
  @@map("specs")
}

// ========================
// 영웅
// ========================

model HeroTemplate {
  id            Int     @id @default(autoincrement())
  name          String
  specId        Int     @map("spec_id")
  raceId        Int     @map("race_id")
  elementId     Int     @map("element_id")
  factionId     Int?    @map("faction_id")
  rarity        String  @default("normal") // normal, rare, epic
  baseHp        Int     @map("base_hp")
  baseAtk       Int     @map("base_atk")
  baseDef       Int     @map("base_def")
  baseSpeed     Int     @map("base_speed")
  aggroRadius   Int     @default(0) @map("aggro_radius")
  attackRange   Int     @map("attack_range")
  description   String?
  isAchievement Boolean @default(false) @map("is_achievement")

  spec     Spec     @relation(fields: [specId], references: [id])
  race     Race     @relation(fields: [raceId], references: [id])
  element  Element  @relation(fields: [elementId], references: [id])
  faction  Faction? @relation(fields: [factionId], references: [id])

  userHeroes UserHero[]

  @@map("hero_templates")
}

model Skill {
  id          Int     @id @default(autoincrement())
  specId      Int     @map("spec_id")
  name        String
  displayName String  @map("display_name")
  skillType   String  @map("skill_type")  // damage, heal, buff, debuff, taunt, cc, summon
  targetType  String  @map("target_type") // single, aoe, self, ally, enemy
  damage      Int     @default(0)
  heal        Int     @default(0)
  duration    Float   @default(0)
  cooldown    Float
  range       Int     @default(0)
  radius      Int     @default(0)
  description String?

  spec Spec @relation(fields: [specId], references: [id])

  @@map("skills")
}

model TalentNode {
  id            Int    @id @default(autoincrement())
  specId        Int    @map("spec_id")
  requiredLevel Int    @map("required_level")
  name          String
  description   String
  effectJson    Json   @map("effect_json")

  spec         Spec              @relation(fields: [specId], references: [id])
  userTalents  UserHeroTalent[]

  @@map("talent_nodes")
}

// ========================
// 유저 영웅 (보유/성장)
// ========================

model UserHero {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  templateId   Int      @map("template_id")
  level        Int      @default(1)
  experience   Int      @default(0)
  talentPoints Int      @default(0) @map("talent_points")
  saveData     Json?    @map("save_data")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  template HeroTemplate @relation(fields: [templateId], references: [id])
  talents  UserHeroTalent[]

  @@unique([userId, templateId])
  @@map("user_heroes")
}

model UserHeroTalent {
  id           Int @id @default(autoincrement())
  userHeroId   Int @map("user_hero_id")
  talentNodeId Int @map("talent_node_id")

  userHero   UserHero   @relation(fields: [userHeroId], references: [id], onDelete: Cascade)
  talentNode TalentNode @relation(fields: [talentNodeId], references: [id])

  @@unique([userHeroId, talentNodeId])
  @@map("user_hero_talents")
}

// ========================
// 게임 세션
// ========================

model GameSession {
  id         Int       @id @default(autoincrement())
  mode       String    // solo, party, raid_10, raid_15
  maxWave    Int       @default(0) @map("max_wave")
  isCleared  Boolean   @default(false) @map("is_cleared")
  towerLevel Int       @default(1) @map("tower_level")
  startedAt  DateTime  @default(now()) @map("started_at")
  endedAt    DateTime? @map("ended_at")

  players GameSessionPlayer[]

  @@map("game_sessions")
}

model GameSessionPlayer {
  id        Int  @id @default(autoincrement())
  sessionId Int  @map("session_id")
  userId    Int  @map("user_id")
  partyJson Json @map("party_json")

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@map("game_session_players")
}

// ========================
// 업적
// ========================

model Achievement {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  displayName   String  @map("display_name")
  description   String
  conditionJson Json    @map("condition_json")
  rewardHeroId  Int?    @map("reward_hero_id")
  rewardGold    Int     @default(0) @map("reward_gold")
  rewardCrystals Int    @default(0) @map("reward_crystals")

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  achievementId Int      @map("achievement_id")
  achievedAt    DateTime @default(now()) @map("achieved_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ========================
// 채팅
// ========================

model ChatMessage {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int?     @map("receiver_id")
  roomId     String?  @map("room_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  sender User @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}
